# Flyto2 Warroom enterprise simulation.
# Copy this file to install/.env.ee-sim and fill local-only secrets there.

FLYTO_WARROOM_ENGINE_IMAGE=docker.io/flyto2/warroom
FLYTO_WARROOM_ENGINE_TAG=engine-ce
FLYTO_WARROOM_WORKER_IMAGE=docker.io/flyto2/warroom
FLYTO_WARROOM_WORKER_TAG=worker-ce
FLYTO_WARROOM_SCHEDULER_IMAGE=docker.io/flyto2/warroom
FLYTO_WARROOM_SCHEDULER_TAG=scheduler-ce
FLYTO_WARROOM_ANALYSIS_IMAGE=docker.io/flyto2/warroom
FLYTO_WARROOM_ANALYSIS_TAG=analysis-ce
FLYTO_WARROOM_REPORT_IMAGE=docker.io/flyto2/warroom
FLYTO_WARROOM_REPORT_TAG=report-ce
FLYTO_WARROOM_FRONTEND_IMAGE=docker.io/flyto2/warroom
FLYTO_WARROOM_FRONTEND_TAG=code-ce
POSTGRES_USER=flyto
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_DB=flyto
FLYTO_ENV=development
FLYTO_DEPLOYMENT_ID=local-ee-sim
FLYTO_ENTERPRISE_JWT_SECRET_KEY=
FLYTO_ENTERPRISE_JWT_PREVIOUS_SECRET_KEYS=

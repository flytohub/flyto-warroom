# Flyto2 Warroom enterprise simulation.
# Copy this file to install/.env.ee-sim and fill local-only secrets there.

FLYTO_WARROOM_ENGINE_IMAGE=docker.io/flyto2/warroom
FLYTO_WARROOM_ENGINE_TAG=engine-ce
FLYTO_WARROOM_WORKER_IMAGE=docker.io/flyto2/warroom
FLYTO_WARROOM_WORKER_TAG=worker-ce
FLYTO_WARROOM_FRONTEND_IMAGE=docker.io/flyto2/warroom
FLYTO_WARROOM_FRONTEND_TAG=code-ce
FLYTO_WARROOM_RUNNER_IMAGE=docker.io/flyto2/warroom
FLYTO_WARROOM_RUNNER_TAG=runner-ce
FLYTO_WARROOM_VERIFICATION_IMAGE=docker.io/flyto2/warroom
FLYTO_WARROOM_VERIFICATION_TAG=verification-ce
FLYTO_WARROOM_BRAND_VISION_IMAGE=docker.io/flyto2/warroom
FLYTO_WARROOM_BRAND_VISION_TAG=brand-vision-ce
FLYTO_WARROOM_PDF_IMAGE=docker.io/flyto2/warroom
FLYTO_WARROOM_PDF_TAG=pdf-ce
POSTGRES_USER=flyto
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_DB=flyto
FLYTO_ENV=development
FLYTO_DEPLOYMENT_ID=local-ee-sim
FLYTO_ENTERPRISE_JWT_SECRET_KEY=
FLYTO_ENTERPRISE_JWT_PREVIOUS_SECRET_KEYS=
FLYTO_RUNNER_SECRET=
FLYTO_VERIFICATION_SECRET=
FLYTO_MASTER_KEY=
FLYTO_MASTER_KEY_ID=local-ee-sim
FLYTO_AI_BASE_URL=http://host.docker.internal:11434/v1
OPENAI_API_KEY=

# Flyto2 Warroom CE local install.
# Copy this file to install/.env and keep the copy out of git.

FLYTO_WARROOM_ENGINE_IMAGE=docker.io/chesterhsu/flyto-warroom
FLYTO_WARROOM_ENGINE_TAG=engine-ce
FLYTO_WARROOM_WORKER_IMAGE=docker.io/chesterhsu/flyto-warroom
FLYTO_WARROOM_WORKER_TAG=worker-ce
FLYTO_WARROOM_FRONTEND_IMAGE=docker.io/chesterhsu/flyto-warroom
FLYTO_WARROOM_FRONTEND_TAG=code-ce
FLYTO_WARROOM_RUNNER_IMAGE=docker.io/chesterhsu/flyto-warroom
FLYTO_WARROOM_RUNNER_TAG=runner-ce
FLYTO_WARROOM_VERIFICATION_IMAGE=docker.io/chesterhsu/flyto-warroom
FLYTO_WARROOM_VERIFICATION_TAG=verification-ce
FLYTO_WARROOM_BRAND_VISION_IMAGE=docker.io/chesterhsu/flyto-warroom
FLYTO_WARROOM_BRAND_VISION_TAG=brand-vision-ce
FLYTO_WARROOM_PDF_IMAGE=docker.io/chesterhsu/flyto-warroom
FLYTO_WARROOM_PDF_TAG=pdf-ce
POSTGRES_USER=flyto
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_DB=flyto
FLYTO_ENV=development
FLYTO_ENGINE_PORT=8080
FLYTO_CODE_PORT=8088
FLYTO_LOCAL_AUTH_EMAIL=local-admin@example.invalid
FLYTO_LOCAL_AUTH_PASSWORD_SHA256=
FLYTO_LOCAL_AUTH_JWT_SECRET=
FLYTO_LOCAL_AUTH_DISPLAY_NAME=Local Admin
FLYTO_LOCAL_AUTH_USER_ID=local-admin
FLYTO_LOCAL_AUTH_ORG_ID=local-warroom
FLYTO_LOCAL_AUTH_ORG_NAME=Flyto2 Warroom
FLYTO_LOCAL_AUTH_ORG_SLUG=flyto2-warroom
FLYTO_PLATFORM_ADMIN_UIDS=
FLYTO_RUNNER_SECRET=
FLYTO_VERIFICATION_SECRET=
FLYTO_MASTER_KEY=
FLYTO_MASTER_KEY_ID=local-ce
OPENAI_API_KEY=
GOOGLE_PAGESPEED_KEY=
FLYTO_GITHUB_TOKEN=

# Flyto2 Warroom CE local install.
# Copy this file to install/.env and keep the copy out of git.
# The generated release tree pins immutable versioned image tags.

FLYTO_WARROOM_ENGINE_IMAGE=docker.io/flyto2/warroom
FLYTO_WARROOM_ENGINE_TAG=engine-ce-0.5.0
FLYTO_WARROOM_WORKER_IMAGE=docker.io/flyto2/warroom
FLYTO_WARROOM_WORKER_TAG=worker-ce-0.5.0
FLYTO_WARROOM_SCHEDULER_IMAGE=docker.io/flyto2/warroom
FLYTO_WARROOM_SCHEDULER_TAG=scheduler-ce-0.5.0
FLYTO_WARROOM_ANALYSIS_IMAGE=docker.io/flyto2/warroom
FLYTO_WARROOM_ANALYSIS_TAG=analysis-ce-0.5.0
FLYTO_WARROOM_REPORT_IMAGE=docker.io/flyto2/warroom
FLYTO_WARROOM_REPORT_TAG=report-ce-0.5.0
FLYTO_WARROOM_FRONTEND_IMAGE=docker.io/flyto2/warroom
FLYTO_WARROOM_FRONTEND_TAG=code-ce-0.5.0
POSTGRES_USER=flyto
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_DB=flyto
FLYTO_POSTGRES_PORT=5432
FLYTO_ENGINE_PORT=8080
FLYTO_WORKER_PORT=8081
FLYTO_SCHEDULER_PORT=8082
FLYTO_ANALYSIS_PORT=8083
FLYTO_REPORT_PORT=8084
FLYTO_CODE_PORT=8088
FLYTO_CE_SCAN_INTERVAL=24h
FLYTO_LOCAL_AUTH_ALLOW_BOOTSTRAP=1
FLYTO_LOCAL_AUTH_JWT_SECRET=

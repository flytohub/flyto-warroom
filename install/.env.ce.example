# Flyto2 Warroom CE local install.
# Copy this file to install/.env and keep the copy out of git.
# The generated release tree pins immutable versioned image tags.

FLYTO_WARROOM_ENGINE_IMAGE=docker.io/chesterhsu/flyto-warroom
FLYTO_WARROOM_ENGINE_TAG=engine-ce-0.4.0
FLYTO_WARROOM_WORKER_IMAGE=docker.io/chesterhsu/flyto-warroom
FLYTO_WARROOM_WORKER_TAG=worker-ce-0.4.0
FLYTO_WARROOM_FRONTEND_IMAGE=docker.io/chesterhsu/flyto-warroom
FLYTO_WARROOM_FRONTEND_TAG=code-ce-0.4.0
POSTGRES_USER=flyto
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_DB=flyto
FLYTO_POSTGRES_PORT=5432
FLYTO_ENGINE_PORT=8080
FLYTO_WORKER_PORT=8081
FLYTO_CODE_PORT=8088
FLYTO_LOCAL_AUTH_ALLOW_BOOTSTRAP=1
FLYTO_LOCAL_AUTH_JWT_SECRET=

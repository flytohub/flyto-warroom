{
  "name": "@flyto2/design-tokens",
  "version": "0.1.1",
  "description": "Shared design tokens for the Flyto2 Platform — purple/cyan brand, dark-first, used by flyto-cloud (Vue + UnoCSS) and flyto-cortex (React + Mantine + Tailwind).",
  "keywords": [
    "flyto2",
    "design-tokens",
    "design-system",
    "css-variables",
    "dark-mode",
    "workflow-automation"
  ],
  "type": "module",
  "scripts": {
    "build": "npm pack --dry-run",
    "docs:generate": "node scripts/generate-reference.mjs",
    "docs:check": "node scripts/generate-reference.mjs --check",
    "lint": "node --check src/index.js && node --check scripts/check-tokens.mjs && node --check scripts/generate-reference.mjs",
    "test": "node scripts/check-tokens.mjs",
    "check": "npm run lint && npm test",
    "verify": "npm run docs:check && npm run lint && npm test && npm run build"
  },
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    },
    "./css": "./css/tokens.css",
    "./css/animations": "./css/animations.css",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "css",
    "docs/API.md",
    "docs/FEATURES.md",
    "docs/GENERATED_REFERENCE.md",
    "README.md",
    "CONTRIBUTING.md"
  ],
  "author": "Flyto2 (https://flyto2.com)",
  "license": "Apache-2.0",
  "homepage": "https://flyto2.com",
  "bugs": { "url": "https://github.com/flytohub/flyto-design-tokens/issues" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flytohub/flyto-design-tokens.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}

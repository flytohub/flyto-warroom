{
  "$schema": "https://docs.flyto2.com/schemas/documentation-contract-v1.json",
  "schema_version": 1,
  "schema": "flyto-code.documentation.v1",
  "repository": "flyto-code",
  "status": "active",
  "audiences": [
    "security operators",
    "frontend contributors",
    "release reviewers"
  ],
  "documentation": {
    "index": "docs/README.md",
    "overview": "README.md",
    "whitepaper": "docs/WHITEPAPER.md",
    "features": "docs/FEATURES.md",
    "feature_reference": "docs/FEATURES.md",
    "security": "SECURITY.md",
    "architecture": "docs/ARCHITECTURE.md",
    "frontend": "docs/FRONTEND.md",
    "api_clients": "docs/API_CLIENTS.md",
    "configuration": "docs/CONFIGURATION.md",
    "testing": "docs/TESTING.md",
    "operations": "docs/OPERATIONS.md",
    "source_reference": [
      "docs/reference/source-api.md",
      "docs/reference/python-automation.md"
    ],
    "source_reference_exclude": [
      "e2e/**",
      "**/__tests__/**",
      "**/*.test.*",
      "**/*.spec.*",
      ".semgrep/**",
      "src-next/test/**",
      "public/mockServiceWorker.js",
      "vendor/**"
    ],
    "route_reference": "docs/reference/routes-and-modules.md",
    "http_reference": "docs/reference/http-and-environment.md"
  },
  "source_areas": [
    {
      "name": "end-to-end tests",
      "paths": [
        "e2e/**"
      ],
      "documentation": [
        "docs/TESTING.md",
        "e2e/README.md"
      ]
    },
    {
      "name": "public assets and runtime bootstrap",
      "paths": [
        "public/**"
      ],
      "documentation": [
        "docs/FRONTEND.md",
        "public/README.md"
      ]
    },
    {
      "name": "repository automation",
      "paths": [
        "scripts/**"
      ],
      "documentation": [
        "docs/TESTING.md",
        "docs/OPERATIONS.md",
        "scripts/README.md",
        "docs/reference/source-api.md",
        "docs/reference/python-automation.md"
      ]
    },
    {
      "name": "authentication adapters",
      "paths": [
        "src-next/@auth/**"
      ],
      "documentation": [
        "docs/FRONTEND.md",
        "docs/CONFIGURATION.md",
        "docs/reference/source-api.md"
      ]
    },
    {
      "name": "Fuse shell",
      "paths": [
        "src-next/@fuse/**"
      ],
      "documentation": [
        "docs/ARCHITECTURE.md",
        "docs/FRONTEND.md",
        "docs/reference/source-api.md"
      ]
    },
    {
      "name": "template adapters and fixtures",
      "paths": [
        "src-next/@i18n/**",
        "src-next/@mock-utils/**"
      ],
      "documentation": [
        "docs/FRONTEND.md",
        "docs/reference/http-and-environment.md",
        "docs/reference/source-api.md"
      ]
    },
    {
      "name": "application routes",
      "paths": [
        "src-next/app/**"
      ],
      "documentation": [
        "docs/FEATURES.md",
        "docs/FRONTEND.md",
        "docs/reference/routes-and-modules.md",
        "docs/reference/source-api.md"
      ]
    },
    {
      "name": "product components",
      "paths": [
        "src-next/components/**"
      ],
      "documentation": [
        "docs/FEATURES.md",
        "docs/FRONTEND.md",
        "docs/reference/source-api.md"
      ]
    },
    {
      "name": "state and providers",
      "paths": [
        "src-next/configs/**",
        "src-next/contexts/**",
        "src-next/hooks/**"
      ],
      "documentation": [
        "docs/ARCHITECTURE.md",
        "docs/FRONTEND.md",
        "docs/reference/source-api.md"
      ]
    },
    {
      "name": "engine and cloud clients",
      "paths": [
        "src-next/lib/engine/**",
        "src-next/lib/cloud/**"
      ],
      "documentation": [
        "docs/API_CLIENTS.md",
        "docs/reference/http-and-environment.md",
        "docs/reference/source-api.md"
      ]
    },
    {
      "name": "shared runtime libraries",
      "paths": [
        "src-next/lib/**"
      ],
      "documentation": [
        "docs/ARCHITECTURE.md",
        "docs/FRONTEND.md",
        "docs/reference/source-api.md"
      ]
    },
    {
      "name": "module and type contracts",
      "paths": [
        "src-next/modules/**",
        "src-next/types/**"
      ],
      "documentation": [
        "docs/FEATURES.md",
        "docs/ARCHITECTURE.md",
        "docs/reference/routes-and-modules.md",
        "docs/reference/source-api.md"
      ]
    },
    {
      "name": "styles and utilities",
      "paths": [
        "src-next/styles/**",
        "src-next/styles-legacy/**",
        "src-next/test/**",
        "src-next/utils/**",
        "src-next/*.ts",
        "src-next/*.tsx"
      ],
      "documentation": [
        "docs/FRONTEND.md",
        "docs/TESTING.md",
        "docs/reference/source-api.md"
      ]
    },
    {
      "name": "vendored design tokens",
      "paths": [
        "vendor/**"
      ],
      "documentation": [
        "docs/ARCHITECTURE.md",
        "docs/FRONTEND.md"
      ]
    },
    {
      "name": "root build and deployment configuration",
      "paths": [
        ".env.example",
        "Dockerfile",
        "eslint.config.js",
        "index-next.html",
        "nginx.conf",
        "package.json",
        "playwright.config.ts",
        "playwright.ctem.config.ts",
        "tsconfig.app.json",
        "tsconfig.json",
        "tsconfig.node.json",
        "vite.config.next.ts",
        "vitest.config.ts"
      ],
      "documentation": [
        "docs/CONFIGURATION.md",
        "docs/TESTING.md",
        "docs/OPERATIONS.md"
      ]
    }
  ]
}

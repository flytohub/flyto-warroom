# Flyto2 Warroom CE frontend runtime.
# Copy this file only for local frontend development. Docker Compose injects the
# production values for the published code-ce image.

VITE_AUTH_MODE=local_jwt
VITE_ENGINE_URL=http://localhost:8080
VITE_AUTOMATION_URL=http://localhost:8080
VITE_CORTEX_URL=http://localhost:8080

# Optional OAuth app IDs for repository connection flows. Leave blank unless
# you have created your own public OAuth apps.
VITE_GITHUB_CLIENT_ID=
VITE_GITHUB_APP_SLUG=
VITE_GITLAB_CLIENT_ID=
VITE_GITLAB_BASE_URL=https://gitlab.com

# CE does not require Firebase and must not enable dev auth bypass.
VITE_DEV_AUTH_BYPASS=0

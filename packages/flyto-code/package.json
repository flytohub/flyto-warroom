{
  "name": "flyto-warroom-ce-frontend",
  "private": true,
  "license": "PolyForm-Noncommercial-1.0.0",
  "version": "0.5.2",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ce.ts --open /index-ce.html",
    "typecheck": "tsc --noEmit -p tsconfig.ce.json",
    "lint": "npm run typecheck",
    "build": "npm run typecheck && vite build --config vite.config.ce.ts",
    "preview": "vite preview --config vite.config.ce.ts --open /index-ce.html",
    "test": "node src-ce/product-shell.contract.test.mjs && npm run typecheck"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.10"
  }
}

{
  "name": "flyto-code",
  "private": true,
  "license": "Apache-2.0",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.next.ts --configLoader runner --open",
    "build": "tsc -b && vite build --config vite.config.next.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "gen:api": "openapi-typescript ../flyto-engine/api/openapi.yaml -o src-next/lib/engine/openapi-schema.gen.ts",
    "sync:backend-routes": "node scripts/sync-backend-routes.mjs",
    "check:backend-routes": "node scripts/sync-backend-routes.mjs --check",
    "build:stats": "BUNDLE_STATS=1 npm run build",
    "check:routes": "python3 scripts/check-route-drift.py",
    "audit:routes-unused": "python3 scripts/check-route-drift.py --strict --report-unused",
    "audit:closure": "node scripts/audit-frontend-closure.mjs --fail-on-mutation-gaps --fail-on-inline-query-keys",
    "audit:loops": "node scripts/audit-platform-loops.mjs",
    "audit:module-matrix": "node scripts/audit-flyto2-module-matrix.mjs",
    "audit:saas-contract": "node scripts/audit-saas-contract.mjs",
    "audit:product-surface-closure": "node scripts/audit-product-surface-closure.mjs",
    "audit:authz-gates": "node scripts/audit-authz-gates.mjs",
    "audit:navbar-smoke": "node scripts/audit-navbar-smoke-registry.mjs",
    "audit:ui-interactions": "node scripts/audit-ui-interactions.mjs",
    "audit:boy-wording": "node scripts/audit-boy-wording.mjs",
    "audit:i18n-hardcoded": "node scripts/audit-i18n-hardcoded.mjs",
    "audit:loop-runtime": "node scripts/audit-loop-runtime.mjs",
    "audit:sse-correspondence": "node scripts/audit-sse-correspondence.mjs",
    "audit:product-verification": "node scripts/audit-product-verification-cockpit.mjs",
    "audit:module-packages": "node scripts/audit-module-package-boundaries.mjs",
    "audit:module-physical-boundaries": "node scripts/audit-module-physical-boundaries.mjs",
    "audit:design-system-boundary": "node scripts/audit-design-system-boundary.mjs",
    "audit:data-readiness": "node scripts/audit-data-readiness-boundaries.mjs",
    "audit:ux-closure": "node scripts/audit-ux-closure.mjs",
    "audit:visual-system": "node scripts/audit-visual-system.mjs",
    "audit:defensive-ux": "node scripts/audit-defensive-ux.mjs",
    "guard:ai-code": "node scripts/audit-ai-code-quality.mjs",
    "audit:cross-surface": "node scripts/audit-cross-surface-imports.mjs",
    "audit:engine-drift": "node scripts/audit-engine-client-drift.mjs",
    "audit:decision-chain": "node scripts/audit-decision-chain.mjs",
    "audit:platform-depth": "node scripts/audit-platform-depth.mjs",
    "audit:enterprise-airgap": "node scripts/audit-enterprise-airgap.mjs",
    "audit:edition-boundary": "node scripts/audit-edition-boundary.mjs",
    "audit:self-hosted-nginx": "node scripts/audit-self-hosted-nginx.mjs",
    "audit:community-export": "node scripts/export-community.mjs --check",
    "audit:workspace-closure": "node scripts/audit-workspace-closure.mjs",
    "audit:page-guards": "node scripts/audit-page-guards.mjs",
    "smoke:product-verification": "FLYTO_PRODUCT_VERIFY_FULL_STACK=1 playwright test e2e/product_verification_evidence.spec.ts --project=chromium",
    "smoke:product-verification:scheduler": "FLYTO_PRODUCT_VERIFY_FULL_STACK=1 FLYTO_PRODUCT_VERIFY_SCHEDULER_SMOKE=1 playwright test e2e/product_verification_evidence.spec.ts --project=chromium",
    "export:community": "node scripts/export-community.mjs",
    "vendor:smoke": "node ../flyto-engine/scripts/manual-vendor-smoke.mjs",
    "guard:branch": "node scripts/ai-branch-guard.mjs",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "compliance:ci": "node scripts/ci-compliance-evidence.mjs",
    "release:bundle-budget": "node scripts/check-release-bundle-budget.mjs",
    "release:static-smoke": "node scripts/release-static-smoke.mjs",
    "release:deploy-policy": "node scripts/check-release-deploy-policy.mjs",
    "audit:github-actions-startup": "node scripts/audit-github-actions-startup.mjs",
    "release:evidence": "node scripts/write-release-evidence.mjs",
    "release:gate": "node scripts/release-gate.mjs"
  },

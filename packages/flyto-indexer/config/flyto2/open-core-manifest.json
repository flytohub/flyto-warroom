{
  "schema": "flyto.open-core-manifest.v1",
  "package_name": "flyto2-warroom-ce",
  "strategy": {
    "model": "open-core",
    "product": "Flyto2 Warroom",
    "source_of_truth": "private Flyto2 workspace",
    "export_mode": "deterministic whitelist with fail-closed deny guards",
    "merge_rule": "Change private source first, rerun exporter, review generated delta."
  },
  "release": {
    "name": "flyto2-warroom-ce",
    "display_name": "Flyto2 Warroom CE",
    "generate": [
      "warroom-ce-installer"
    ],
    "public_image_repository": "docker.io/chesterhsu/flyto-warroom",
    "public_images": {
      "engine": "docker.io/chesterhsu/flyto-warroom",
      "worker": "docker.io/chesterhsu/flyto-warroom",
      "frontend": "docker.io/chesterhsu/flyto-warroom",
      "runner": "docker.io/chesterhsu/flyto-warroom",
      "verification": "docker.io/chesterhsu/flyto-warroom",
      "brand_vision": "docker.io/chesterhsu/flyto-warroom",
      "pdf": "docker.io/chesterhsu/flyto-warroom"
    },
    "public_image_tags": {
      "engine": "engine-ce",
      "worker": "worker-ce",
      "frontend": "code-ce",
      "runner": "runner-ce",
      "verification": "verification-ce",
      "brand_vision": "brand-vision-ce",
      "pdf": "pdf-ce"
    },
    "public_image_digests": {
      "engine": "sha256:4f6e7911e9fffc795b09e61d04206e37c6a5e3316dff1d61032d8cc0626b2527",
      "worker": "sha256:4f6e7911e9fffc795b09e61d04206e37c6a5e3316dff1d61032d8cc0626b2527",
      "frontend": "sha256:de8537658a123398c837ef72078a6c1370728e8add464ab9257d157caf694175",
      "runner": "sha256:239744f8753365b4e82f08628a9964aa6364ce8d37823f92ad83dcf915d75774",
      "verification": "sha256:ae3f5da8571eb1ee877ec4baf8c0e430f91ff73a878f8e2eeb9b07aae0eb8a90",
      "brand_vision": "sha256:f83f2a3b3c3e3de9313077646c57c769d9ca303746d1d02312d808cbab5074ad",
      "pdf": "sha256:f428b27543a1745b2b9586260964f8bb2687e877aaf3a7491134c8a4d40e0889"
    }
  },
  "global_exclude": [
    ".git/**",
    ".flyto/**",
    ".flyto-index/**",
    ".flyto-runs/**",
    ".hypothesis/**",
    ".mypy_cache/**",
    ".pytest_cache/**",
    ".ruff_cache/**",
    ".venv/**",
    ".venv-sec/**",
    "**/__pycache__/**",
    "**/*.pyc",
    "build/**",
    "node_modules/**",
    "out/**",
    "output/**",
    "reports/**"
  ],
  "deny_content_patterns": [
    "sk_live_[A-Za-z0-9]{16,}",
    "sk_test_[A-Za-z0-9]{16,}",
    "AIza[0-9A-Za-z_-]{20,}",
    "ghp_[0-9A-Za-z_]{20,}",
    "github_pat_[0-9A-Za-z_]{20,}",
    "xox[baprs]-[0-9A-Za-z-]{20,}",
    "BEGIN (RSA |EC |OPENSSH |)PRIVATE KEY",
    "STRIPE_SECRET_KEY\\s*=\\s*[^\\s$<]+",
    "FIREBASE_PRIVATE_KEY\\s*=\\s*[^\\s$<]+",
    "FLYTO_VERIFICATION_SECRET[ \\t]*=[ \\t]*[^\\s$<]+",
    "FLYTO_RUNNER_SECRET[ \\t]*=[ \\t]*[^\\s$<]+"
  ],
  "closed_source_boundaries": [
    "billing, entitlement mutation, commercial gates, and Stripe/offline-license adapters",
    "enterprise SSO/SAML/SCIM, legal hold, airgap installers, deployment edition internals",
    "darkweb, stealer-log, phishing-feed, commercial threat-intel, and proprietary correlation datasets",
    "cloud/container/runtime live remediation orchestration and customer connector credentials",
    "Flyto Cloud multi-tenant SaaS control plane, runner fleet control, and hosted telemetry",
    "AutoFix promotion, approval, rollback orchestration, and commercial AI proposal workflows",
    "hosted SaaS-only frontend configuration, private preview credentials, and enterprise image publishing metadata"
  ],
  "merge_contracts": [
    "OSS exports are generated artifacts; do not hand-edit generated community trees.",
    "Every package must declare source repo, license, include patterns, protected paths, and deny path patterns.",
    "Exporter fails closed on missing include patterns, missing required paths, protected path inclusion, and denied content markers.",
    "Community packages may call back into enterprise only through documented contracts, not private imports."
  ],
  "packages": [
    {
      "name": "flyto-core",
      "repo": "flyto-core",
      "kind": "runtime-sdk",
      "license": "Apache-2.0",
      "merge_contract": "YAML workflow runtime, deterministic verification, browser/module SDK, plugin contracts.",
      "must_exist": [
        "src/core/modules",
        "src/core/engine",
        "src/recipes/warroom-deterministic-audit.yaml",
        "docs/YAML_WORKFLOW_SPEC.md"
      ],
      "include": [
        "LICENSE",
        "NOTICE",
        "README.md",
        "SECURITY.md",
        "CONTRIBUTING.md",
        "CODE_OF_CONDUCT.md",
        "pyproject.toml",
        "MANIFEST.in",
        "src/cli/**",
        "src/core/analysis/**",
        "src/core/api/**",
        "src/core/browser/**",
        "src/core/catalog/**",
        "src/core/engine/**",
        "src/core/modules/**",
        "src/core/plugin/**",
        "src/core/runtime/**",
        "src/core/testing/**",
        "src/core/validation/**",
        "src/core/verification_service.py",
        "src/recipe_bundles/**",
        "src/recipes/**",
        "docs/**",
        "examples/spec-verify/**",
        "plugin-template/**",
        "tests/cli/**",
        "tests/core/**",
        "tests/modules/**",
        "tests/runtime/**",
        "tests/test_verification_service.py"
      ],
      "exclude": [
        "src/core/enterprise/**",
        "src/core/licensing/**",
        "src/core/metering/**",
        "src/core/secrets/**",
        "tests/enterprise/**",
        "tests/core/test_step_executor_real.py",
        "tests/core/test_trace_checkpoint_redaction.py",
        "tests/runtime/test_security.py"
      ],
      "protected_paths": [
        "src/core/enterprise/**",
        "src/core/licensing/**",
        "src/core/metering/**",
        "src/core/secrets/**",
        "tests/enterprise/**"
      ],
      "deny_path_patterns": [
        "src/core/enterprise/**",
        "src/core/licensing/**",
        "src/core/metering/**",
        "src/core/secrets/**",
        "tests/enterprise/**"
      ]
    },
    {
      "name": "flyto-indexer",
      "repo": "flyto-indexer",
      "kind": "local-code-intelligence",
      "license": "Apache-2.0",
      "merge_contract": "Local-first static analysis, impact, taint, dependency, SBOM, release evidence gates.",
      "must_exist": [
        "src/cli.py",
        "src/verify.py",
        "src/scanner",
        "src/analyzer",
        "tests/test_verify.py"
      ],
      "include": [
        "LICENSE",
        "NOTICE",
        "README.md",
        "SECURITY.md",
        "CONTRIBUTING.md",
        "TRADEMARK.md",
        "pyproject.toml",
        "Dockerfile",
        "src/**",
        "tests/**",
        "config/**",
        "docs/**",
        "examples/**",
        "integrations/**",
        "mcp_config.example.json",
        "server.json",
        "run_mcp.sh"
      ],
      "exclude": [
        "dist/**",
        ".mcp/**",
        "tests/test_secret_scanner_filters.py"
      ],
      "protected_paths": [
        "dist/**"
      ],
      "deny_path_patterns": [
        "dist/**"
      ]
    },
    {
      "name": "flyto-i18n",
      "repo": "flyto-i18n",
      "kind": "shared-locales",
      "license": "MIT",
      "merge_contract": "Shared locale source and generated dist consumed by Flyto frontends and engine messages.",
      "must_exist": [
        "locales",
        "dist",
        "scripts/validate.py",
        "scripts/build-dist.py"
      ],
      "include": [
        "LICENSE",
        "README.md",
        "SECURITY.md",
        "CONTRIBUTING.md",
        "package.json",
        "Makefile",
        "locales/**",
        "dist/**",
        "schema/**",
        "scripts/*.py",
        "tests/**"
      ],
      "exclude": [
        "scripts/one-off/**"
      ],
      "protected_paths": [
        "scripts/one-off/**"
      ],
      "deny_path_patterns": [
        "scripts/one-off/**"
      ]
    },
    {
      "name": "flyto-code",
      "repo": "flyto-code",
      "kind": "warroom-frontend",
      "license": "Apache-2.0",
      "merge_contract": "React/Vite Warroom CE frontend, capability-gated cockpit, i18n runtime, and UI audit scripts.",
      "must_exist": [
        "src-next",
        "public",
        "package.json",
        "vite.config.next.ts",
        "vendor/@flyto/design-tokens"
      ],
      "include": [
        "README.md",
        "SECURITY.md",
        "CONTRIBUTING.md",
        "package.json",
        "package-lock.json",
        ".npmrc",
        "Dockerfile",
        "nginx.conf",
        "index-next.html",
        "eslint.config.js",
        "vite.config.next.ts",
        "vitest.config.ts",
        "playwright.config.ts",
        "playwright.ctem.config.ts",
        "tsconfig*.json",
        "src-next/**",
        "public/**",
        "docs/**",
        "e2e/**",
        "scripts/**",
        "vendor/**"
      ],
      "generate": [
        "flyto-code-public-metadata"
      ],
      "exclude": [
        ".env",
        ".env.*",
        ".flyto-index/**",
        ".flyto-rules.yaml",
        ".github/**",
        ".gitleaks.toml",
        ".semgrep/**",
        "AGENTS.md",
        "CLAUDE.md",
        "ARCHITECTURE.md",
        "DECISIONS.md",
        "PROJECT.md",
        "ROADMAP.md",
        "STATE.md",
        "CHANGELOG.md",
        "REFACTOR_PLAN.md",
        "tasks.md",
        "dist/**",
        "dist-next/**",
        "node_modules/**",
        "out/**",
        "reports/**",
        "test-results/**",
        "lh.json",
        "scripts/one-off/**"
      ],
      "protected_paths": [
        ".env",
        ".env.*",
        ".flyto-index/**",
        ".github/**",
        "dist/**",
        "dist-next/**",
        "node_modules/**",
        "out/**",
        "reports/**",
        "test-results/**",
        "lh.json"
      ],
      "deny_path_patterns": [
        ".env",
        ".env.*",
        "dist/**",
        "dist-next/**",
        "node_modules/**",
        "out/**",
        "reports/**",
        "test-results/**"
      ]
    },
    {
      "name": "flyto-contracts",
      "repo": "flyto-engine",
      "kind": "protocol-contracts",
      "license": "Apache-2.0",
      "merge_contract": "Open source protocol package for API, capability, scanner, runner, evidence, audit, and product verification contracts.",
      "must_exist": [
        "api/openapi.yaml",
        "internal/permission/capabilities.yaml",
        "docs/project-capabilities.md"
      ],
      "include": [
        "LICENSE",
        "SECURITY.md",
        "CONTRIBUTING.md",
        "api/openapi.yaml",
        "docs/project-capabilities.md",
        "internal/permission/capabilities.yaml"
      ],
      "copy_as": [
        {
          "from": "LICENSE",
          "to": "LICENSE"
        },
        {
          "from": "SECURITY.md",
          "to": "SECURITY.md"
        },
        {
          "from": "CONTRIBUTING.md",
          "to": "CONTRIBUTING.md"
        },
        {
          "from": "api/openapi.yaml",
          "to": "openapi/flyto-engine.openapi.yaml"
        },
        {
          "from": "docs/project-capabilities.md",
          "to": "docs/project-capabilities.md"
        },
        {
          "from": "internal/permission/capabilities.yaml",
          "to": "capabilities/capabilities.yaml"
        }
      ],
      "generate": [
        "flyto-contracts-protocol"
      ],
      "exclude": [
        "internal/billing/**",
        "internal/offlinelicense/**",
        "internal/stealerlogs/**",
        "internal/threatfeed/**",
        "internal/threatintel/**",
        "internal/cloudscan/**",
        "internal/containerlive/**",
        "internal/store/**",
        "api/handlers_billing*",
        "api/handlers_entitlement*",
        "api/handlers_saml*",
        "api/handlers_scim*"
      ],
      "protected_paths": [
        "cmd/**",
        "internal/**",
        "api/handlers_*",
        "api/handlers_billing*",
        "api/handlers_entitlement*",
        "api/handlers_saml*",
        "api/handlers_scim*",
        "internal/billing/**",
        "internal/cloudscan/**",
        "internal/containerlive/**",
        "internal/offlinelicense/**",
        "internal/stealerlogs/**",
        "internal/store/**",
        "internal/threatfeed/**",
        "internal/threatintel/**"
      ],
      "deny_path_patterns": [
        "api/handlers_billing*",
        "api/handlers_entitlement*",
        "api/handlers_saml*",
        "api/handlers_scim*",
        "internal/billing/**",
        "internal/cloudscan/**",
        "internal/containerlive/**",
        "internal/offlinelicense/**",
        "internal/stealerlogs/**",
        "internal/store/**",
        "internal/threatfeed/**",
        "internal/threatintel/**"
      ],
      "deny_export_path_patterns": [
        "cmd/**",
        "internal/**",
        "api/handlers_*"
      ]
    }
  ]
}

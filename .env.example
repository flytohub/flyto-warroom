# Flyto2 Warroom CE root environment reference.
# The running stack reads install/.env, generated by:
#
#   python3 install/scripts/setup-ce.py --email admin@example.com
#
# Keep real secrets out of git. This file documents the public CE knobs only.

POSTGRES_USER=flyto
POSTGRES_DB=flyto
FLYTO_ENV=development
FLYTO_CODE_PORT=8088
FLYTO_ENGINE_PORT=8080
FLYTO_POSTGRES_PORT=5432
FLYTO_RUNNER_PORT=8090
FLYTO_VERIFICATION_PORT=8344
FLYTO_BRAND_VISION_PORT=8095

# Optional public-feed/provider keys. Leave blank for offline CE evaluation.
OPENAI_API_KEY=
GOOGLE_PAGESPEED_KEY=
FLYTO_GITHUB_TOKEN=
FLYTO_ABUSECH_AUTH_KEY=
HIBP_API_KEY=
ABUSEIPDB_API_KEY=
FLYTO_VT_API_KEY=
VIRUSTOTAL_API_KEY=
FLYTO_URLSCAN_API_KEY=
SHODAN_API_KEY=
FLYTO_IPINFO_TOKEN=
